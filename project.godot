; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ShibKart"
config/description="Mario-Kart-style racer for the Boshi universe. Race the 10k Shiboshis (chibi rig via BoshiCore), build your own tracks in the in-game editor and save/load them."
run/main_scene="res://scenes/boot.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

BoshiCore="*res://addons/boshicore/boshi_core.gd"
BoshiBridge="*res://addons/boshicore/boshi_bridge.gd"
GameState="*res://scripts/game_state.gd"
AudioManager="*res://scripts/audio_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"


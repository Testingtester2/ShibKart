{
  "_comment": "Portable ComfyUI txt2img graph for ShibKart game art. Uses only CORE ComfyUI nodes so it runs on almost any install. generate_shibkart_assets.py substitutes {{PROMPT}} {{NEG}} {{SEED}} {{WIDTH}} {{HEIGHT}}. >>> EDIT ckpt_name below to a checkpoint you actually have (e.g. an SDXL or SD1.5 .safetensors in ComfyUI/models/checkpoints). <<<",
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" },
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent" },
    "inputs": { "width": "{{WIDTH}}", "height": "{{HEIGHT}}", "batch_size": 1 }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive" },
    "inputs": { "clip": ["4", 1], "text": "{{PROMPT}}" }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative" },
    "inputs": { "clip": ["4", 1], "text": "{{NEG}}" }
  },
  "3": {
    "class_type": "KSampler",
    "_meta": { "title": "KSampler" },
    "inputs": {
      "model": ["4", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0],
      "seed": "{{SEED}}",
      "steps": 24,
      "cfg": 6.5,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" },
    "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "_meta": { "title": "Save" },
    "inputs": { "images": ["8", 0], "filename_prefix": "shibkart" }
  }
}
